# WaitlistKit Configuration

# Base URL for generated links (landing pages, referral links)
BASE_URL=http://localhost:8430

# SQLite database path
WAITLIST_DB_PATH=/data/waitlist-kit/waitlist.db

# Email provider: "smtp", "resend", or leave empty to disable
EMAIL_PROVIDER=

# SMTP settings (if EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# Resend settings (if EMAIL_PROVIDER=resend)
RESEND_API_KEY=
RESEND_FROM=WaitlistKit <noreply@waitlistkit.dev>
